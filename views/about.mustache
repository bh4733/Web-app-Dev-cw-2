{{> head}}
{{> topnav}}

<section class="about-section">
  <h1>About Us</h1>
  <p>
    Welcome to Yoga Studio — a place for yoga classes at every level, from first-timers to experienced practitioners.
  </p>
</section>

<section class="about-section">
  <h2>Our Classes</h2>
  {{#courses}}
  <article class="about-class">
    <h3>{{title}}</h3>
    <p>
      <span class="badge badge-{{level}}">{{level}}</span>
      {{#allowDropIn}}<span class="badge" style="background:#e0f2fe;color:#075985">Drop-in welcome</span>{{/allowDropIn}}
    </p>
    <p class="muted">{{description}}</p>
    {{#location}}<p class="muted">Location: {{location}}</p>{{/location}}
    {{#price}}<p class="muted">Price: {{price}}</p>{{/price}}
  </article>
  {{/courses}}
  {{^courses}}
  <p class="muted">Classes coming soon — check back shortly.</p>
  {{/courses}}
  <p><a href="/courses" class="btn primary">View schedule &amp; book</a></p>
</section>

<section class="about-section">
  <h2>Location</h2>
  <address class="about-address">
    <strong>Yoga Studio</strong><br>
    12 Serenity Lane<br>
    Brighton<br>
    BN1 1AA<br>
    United Kingdom
  </address>
  <p>
    <strong>Phone:</strong> 01273 000 000<br>
    <strong>Email:</strong> hello@yogastudio.example
  </p>
</section>

{{> footer}}
