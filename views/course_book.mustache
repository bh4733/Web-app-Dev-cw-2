{{> head}}
{{> topnav}}

<article>
  <h1>Book: {{course.title}}</h1>
  <p>
    <span class="badge badge-{{course.level}}">{{course.level}}</span>
    <span class="badge" style="background:#f1f5f9;color:#475569">{{course.type}}</span>
  </p>
  <dl class="kv" style="margin:0.75rem 0">
    <dt>Dates</dt>        <dd>{{course.startDate}} – {{course.endDate}}</dd>
    {{#course.location}}<dt>Location</dt> <dd>{{course.location}}</dd>{{/course.location}}
    {{#course.price}}   <dt>Price</dt>    <dd>{{course.price}}</dd>{{/course.price}}
  </dl>

  {{#errors}}
  <div class="alert error" role="alert" aria-live="assertive">
    <ul>
      {{#list}}
      <li>{{.}}</li>
      {{/list}}
    </ul>
  </div>
  {{/errors}}

  <form method="post" action="/courses/{{course.id}}/book">
    <input type="hidden" name="userId" value="{{user._id}}">

    <fieldset>
      <legend>Your details</legend>
      <div class="field">
        <label for="name">Full name</label>
        <input id="name" name="name" type="text" required value="{{user.name}}">
      </div>
      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required value="{{user.email}}">
      </div>
      <div class="field">
        <label for="notes">Notes (injuries, preferences)</label>
        <textarea id="notes" name="notes" rows="3" placeholder="Optional">{{notes}}</textarea>
      </div>
      <div class="field checkbox">
        <input id="consent" name="consent" type="checkbox" required>
        <label for="consent">I agree to the studio's booking terms &amp; health disclaimer.</label>
      </div>
    </fieldset>

    <fieldset>
      <legend>Booking summary</legend>
      <p>This booking reserves a seat across <strong>{{sessionsCount}}</strong> sessions:</p>
      <ul class="muted" style="margin:0.5rem 0 0 1.25rem">
        {{#sessions}}
        <li>{{start}} ({{remaining}} places left)</li>
        {{/sessions}}
      </ul>
    </fieldset>

    <div class="actions">
      <button class="btn primary" type="submit">Confirm Booking</button>
      <a class="btn" href="/courses/{{course.id}}">Cancel</a>
    </div>
  </form>
</article>

{{> footer}}
