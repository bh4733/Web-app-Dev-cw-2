{{> head}}
{{> topnav}}

<div style="max-width:540px">
  <h1>Booking Confirmed</h1>
  <p class="muted">Your booking has been created successfully.</p>

  <div class="card" style="margin-top:1.25rem">
    <dl class="kv">
      <dt>Booking ID</dt> <dd><code>{{booking.id}}</code></dd>
      <dt>Type</dt>       <dd>{{booking.type}}</dd>
      <dt>Status</dt>
      <dd>
        {{#booking.status}}
        <span class="badge {{#booking.status}}badge-status-{{booking.status}}{{/booking.status}}"
              style="background:{{#booking.isConfirmed}}#dcfce7{{/booking.isConfirmed}}{{^booking.isConfirmed}}#fef9c3{{/booking.isConfirmed}};
                     color:{{#booking.isConfirmed}}#166534{{/booking.isConfirmed}}{{^booking.isConfirmed}}#854d0e{{/booking.isConfirmed}}">
          {{booking.status}}
        </span>
        {{/booking.status}}
      </dd>
      <dt>Created</dt>    <dd>{{booking.createdAt}}</dd>
    </dl>
  </div>

  <div class="actions" style="margin-top:1.25rem">
    <a class="btn primary" href="/courses">Browse more courses</a>
    <a class="btn" href="/">Home</a>
  </div>
</div>

{{> footer}}
