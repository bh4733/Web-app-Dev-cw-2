{{> head}}
{{> header}}

<h1>Manage Users</h1>

{{#errors}}
<div class="alert error" role="alert">
  <ul>
    {{#list}}
    <li>{{.}}</li>
    {{/list}}
  </ul>
</div>
{{/errors}}

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Role</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {{#users}}
    <tr>
      <td><strong>{{name}}</strong></td>
      <td>{{email}}</td>
      <td>
        <span class="badge"
          style="background:{{#isOrganiser}}#ede9fe{{/isOrganiser}}{{^isOrganiser}}#f1f5f9{{/isOrganiser}};
                 color:{{#isOrganiser}}#5b21b6{{/isOrganiser}}{{^isOrganiser}}#475569{{/isOrganiser}}">
          {{role}}
        </span>
      </td>
      <td style="white-space:nowrap">
        {{#isStudent}}
        <form method="post" action="/organiser/users/{{id}}/make-organiser" style="display:inline">
          <button class="btn" type="submit">Make Organiser</button>
        </form>
        {{/isStudent}}
        <form method="post" action="/organiser/users/{{id}}/delete" style="display:inline" onsubmit="return confirm('Remove this user?')">
          <button class="btn btn-danger" type="submit">Remove</button>
        </form>
      </td>
    </tr>
    {{/users}}
    {{^users}}
    <tr><td colspan="4" class="muted" style="text-align:center;padding:1.5rem">No users found.</td></tr>
    {{/users}}
  </tbody>
</table>

<hr style="margin:2rem 0;border:none;border-top:1px solid var(--line)">

<div style="max-width:420px">
  <h2>Add Organiser</h2>
  <form method="post" action="/organiser/users/new">
    <div class="form-group">
      <label for="name">Full name</label>
      <input type="text" id="name" name="name" value="{{values.name}}" required />
    </div>
    <div class="form-group">
      <label for="email">Email address</label>
      <input type="email" id="email" name="email" value="{{values.email}}" required />
    </div>
    <div class="form-group">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required />
    </div>
    <div class="actions">
      <input type="submit" class="btn primary" value="Add Organiser" />
    </div>
  </form>
</div>

{{> footer}}
