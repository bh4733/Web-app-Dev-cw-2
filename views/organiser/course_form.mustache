{{> head}}
{{> topnav}}

<div style="max-width:600px">
  <h1>{{title}}</h1>

  {{#errors}}
  <div class="alert error" role="alert">
    <ul>
      {{#list}}
      <li>{{.}}</li>
      {{/list}}
    </ul>
  </div>
  {{/errors}}

  {{#editing}}
  <form method="post" action="/organiser/courses/{{course.id}}/edit">
  {{/editing}}
  {{^editing}}
  <form method="post" action="/organiser/courses/new">
  {{/editing}}

    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" value="{{course.title}}" required />
    </div>

    <div class="form-group">
      <label for="level">Level</label>
      <select id="level" name="level" required>
        <option value="">-- select --</option>
        <option value="beginner"     {{#course.levelBeginner}}selected{{/course.levelBeginner}}>Beginner</option>
        <option value="intermediate" {{#course.levelIntermediate}}selected{{/course.levelIntermediate}}>Intermediate</option>
        <option value="advanced"     {{#course.levelAdvanced}}selected{{/course.levelAdvanced}}>Advanced</option>
      </select>
    </div>

    <div class="form-group">
      <label for="type">Type</label>
      <select id="type" name="type" required>
        <option value="">-- select --</option>
        <option value="WEEKLY_BLOCK"      {{#course.typeWeekly}}selected{{/course.typeWeekly}}>Weekly Block</option>
        <option value="WEEKEND_WORKSHOP"  {{#course.typeWeekend}}selected{{/course.typeWeekend}}>Weekend Workshop</option>
      </select>
    </div>

    <div class="form-group">
      <label class="field checkbox" style="flex-direction:row;align-items:center;gap:0.6rem;font-weight:400">
        <input type="checkbox" name="allowDropIn" {{#course.allowDropIn}}checked{{/course.allowDropIn}} />
        Allow drop-in sessions
      </label>
    </div>

    <div class="form-group" style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">
      <div>
        <label for="startDate">Start date</label>
        <input type="date" id="startDate" name="startDate" value="{{course.startDate}}" />
      </div>
      <div>
        <label for="endDate">End date</label>
        <input type="date" id="endDate" name="endDate" value="{{course.endDate}}" />
      </div>
    </div>

    <div class="form-group" style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">
      <div>
        <label for="location">Location</label>
        <input type="text" id="location" name="location" value="{{course.location}}" placeholder="e.g. Studio A" />
      </div>
      <div>
        <label for="price">Price</label>
        <input type="text" id="price" name="price" value="{{course.price}}" placeholder="e.g. £40" />
      </div>
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="4">{{course.description}}</textarea>
    </div>

    <div class="actions">
      <input type="submit" class="btn primary" value="{{#editing}}Save Changes{{/editing}}{{^editing}}Add Course{{/editing}}" />
      <a class="btn" href="/organiser/courses">Cancel</a>
    </div>
  </form>
</div>

{{> footer}}
