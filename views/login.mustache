{{> head}}
{{> header}}

<h1>Login</h1>

{{#error}}
<div class="alert error" role="alert" aria-live="assertive">
  <p>{{error}}</p>
</div>
{{/error}}

    <form method="post" action="/login">
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" class="form-control" id="email" name="email" placeholder="Email address" value="{{values.email}}" required/>
        </div>
        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" class="form-control" id="password" name="password" placeholder="Please enter password" required/>
        </div>
        <div class="form-group">
        <input type="submit" value="Login" class="btn btn-primary">
        </div>
    </form>
<p>Don't have an account? <a href="/register">Register</a></p>

{{> footer}}
