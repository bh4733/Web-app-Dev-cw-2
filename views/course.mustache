
{{> head}}
{{> header}}

<article>
  <h1>{{course.title}}</h1>
  <p>
    <span class="badge badge-{{course.level}}">{{course.level}}</span>
    <span class="badge" style="background:#f1f5f9;color:#475569">{{course.type}}</span>
    {{#course.allowDropIn}}<span class="badge" style="background:#e0f2fe;color:#075985">Drop-in OK</span>{{/course.allowDropIn}}
  </p>
  <p>{{course.description}}</p>
  <dl class="kv" style="margin:0.75rem 0">
    <dt>Dates</dt>       <dd>{{course.startDate}} – {{course.endDate}}</dd>
    {{#course.location}}<dt>Location</dt> <dd>{{course.location}}</dd>{{/course.location}}
    {{#course.price}}   <dt>Price</dt>    <dd>{{course.price}}</dd>{{/course.price}}
  </dl>

  <section>
    <h2>Book the full course</h2>
    <a class="btn primary" href="/courses/{{course.id}}/book">Book full course</a>
  </section>

  <section>
    <h2>Sessions</h2>
    <table class="table">
      <thead>
        <tr><th>Start</th><th>End</th><th>Capacity</th><th>Booked</th><th>Remaining</th><th></th></tr>
      </thead>
      <tbody>
        {{#sessions}}
        <tr>
          <td>{{start}}</td>
          <td>{{end}}</td>
          <td>{{capacity}}</td>
          <td>{{booked}}</td>
          <td>{{remaining}}</td>
          <td>
            {{#course.allowDropIn}}
            <form method="post" action="/sessions/{{id}}/book">
              <button class="btn primary" type="submit">Book session</button>
            </form>
            {{/course.allowDropIn}}
            {{^course.allowDropIn}}
            <span class="muted">Drop-ins disabled</span>
            {{/course.allowDropIn}}
          </td>
        </tr>
        {{/sessions}}
      </tbody>
    </table>
  </section>
</article>

{{> footer}}